// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  admin
  member
}

enum AccountStatus {
  pending
  invited
  active
}

enum TaskStatus {
  not_started
  in_progress
  in_review
  completed
}

enum TaskPriority {
  low
  medium
  high
  critical
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  fullName      String
  email         String        @unique
  password      String
  role          Role          @default(member)
  status        AccountStatus @default(pending)

  avatarUrl     String?

  // Temporary tokens
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  magicLinkToken    String?   @unique
  magicLinkExpiry   DateTime?

  // Relations
  taskAssignments TaskAssignee[]
  comments        Comment[]
  boardComments   BoardComment[]
  boardReactions  BoardReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(not_started)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?

  // Relations
  assignees TaskAssignee[]
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model Comment {
  id      String @id @default(cuid())
  content String

  // Relations
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Self-referential for threaded replies
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Comment[] @relation("Replies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model BoardComment {
  id      String @id @default(cuid())
  content String

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // One level of threading
  parentId String?
  parent   BoardComment?  @relation("BoardReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  BoardComment[] @relation("BoardReplies")

  reactions BoardReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("board_comments")
}

model BoardReaction {
  id        String @id @default(cuid())
  emoji     String

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId String
  comment   BoardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("board_reactions")
}
