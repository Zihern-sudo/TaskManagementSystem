// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  admin
  member
}

enum AccountStatus {
  pending
  invited
  active
}

enum TaskStatus {
  not_started
  in_progress
  in_review
  completed
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum FieldType {
  text
  picklist
}

enum FieldEntity {
  task
  user
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  fullName      String
  email         String        @unique
  password         String?
  hasSetPassword   Boolean       @default(false)
  role             Role          @default(member)
  status           AccountStatus @default(pending)

  avatarUrl     String?

  // Temporary tokens
  inviteToken           String?   @unique
  inviteTokenExpiry     DateTime?
  magicLinkToken        String?   @unique
  magicLinkExpiry       DateTime?
  passwordResetToken    String?   @unique
  passwordResetExpiry   DateTime?

  // Relations
  taskAssignments   TaskAssignee[]
  comments          Comment[]
  boardComments     BoardComment[]
  boardReactions    BoardReaction[]
  customFieldValues UserCustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(not_started)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?

  // Self-referential subtask relation
  parentId  String? @map("parent_id")
  parent    Task?   @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks  Task[]  @relation("SubTasks")

  // Relations
  assignees         TaskAssignee[]
  comments          Comment[]
  customFieldValues TaskCustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model Comment {
  id      String @id @default(cuid())
  content String

  // Relations
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Self-referential for threaded replies
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Comment[] @relation("Replies")

  // Pin support
  pinned   Boolean   @default(false)
  pinnedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model BoardComment {
  id      String @id @default(cuid())
  content String

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // One level of threading
  parentId String?
  parent   BoardComment?  @relation("BoardReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  BoardComment[] @relation("BoardReplies")

  reactions BoardReaction[]

  pinned   Boolean   @default(false)
  pinnedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("board_comments")
}

model BoardReaction {
  id        String @id @default(cuid())
  emoji     String

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId String
  comment   BoardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("board_reactions")
}

// ─────────────────────────────────────────────
// Custom Fields
// ─────────────────────────────────────────────

model CustomField {
  id             String      @id @default(cuid())
  label          String
  fieldKey       String      @unique
  type           FieldType
  entity         FieldEntity @default(task)
  showInListView Boolean     @default(false)
  options        String[]    @default([])
  required       Boolean     @default(false)
  order          Int         @default(0)

  taskValues TaskCustomFieldValue[]
  userValues UserCustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_fields")
}

model TaskCustomFieldValue {
  id    String @id @default(cuid())
  value String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  fieldId String
  field   CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([taskId, fieldId])
  @@map("task_custom_field_values")
}

model UserCustomFieldValue {
  id    String @id @default(cuid())
  value String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fieldId String
  field   CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldId])
  @@map("user_custom_field_values")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
